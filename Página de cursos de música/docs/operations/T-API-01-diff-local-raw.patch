+export async function lockLessonSessionForComplete(
+  tx: Prisma.TransactionClient,
+  sessionId: string
+): Promise<void> {
+  await tx.$queryRaw(
+    Prisma.sql`SELECT id FROM "LessonSession" WHERE id::text = ${sessionId} FOR UPDATE`
+  );
