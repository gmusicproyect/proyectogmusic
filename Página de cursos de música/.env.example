# Copiar a .env local (no commitear .env):
#   cp .env.example .env
#
# Desarrollo local: levantar Postgres con docker compose up -d
# DATABASE_URL="postgresql://gmusic_admin:gmusic_secure_password@localhost:5432/gmusic_learning_db?schema=public"
# Staging/producción MVP (Supabase): Connect → Session pooler → Copy URI completa
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# JWT para gmusic_session (obligatorio en producción)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# API Learning Engine (desarrollo local)
API_PORT=3001
# Autenticación SOLO desarrollo — resuelve al alumno sin JWT. No usar en producción.
GMUSIC_DEV_USER_EMAIL=carlos@gmusic.academy
# Clave para POST /api/v1/dev/activate-semestral (solo desarrollo local del API; eliminar antes de producción).
# Mínimo 24 caracteres; no usar el placeholder en entornos reales ni variables VITE_*.
GMUSIC_DEV_ACTIVATION_KEY=change-me-in-local-env

# Frontend (Vite)
VITE_API_BASE_URL=/api/v1
# Producción (Vercel): https://gmusic-api.onrender.com/api/v1
# Local sin API local: proxy Vite /api → Render (origin sin /api/v1). Si VITE_API_BASE_URL
# es una URL http(s) remota, Vite infiere este target automáticamente.
VITE_DEV_API_PROXY_TARGET=https://gmusic-api.onrender.com
# Orígenes permitidos en la API (Render): dominio Vercel + local dev
CORS_ALLOWED_ORIGINS=https://proyectogmusic.vercel.app,http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5174
# Usar true solo para desarrollo UI sin backend (explícito; no oculta errores reales).
VITE_USE_DASHBOARD_MOCK=false
# Usar true solo para desarrollo UI del camino sin backend (explícito; no oculta errores reales).
VITE_USE_PATH_MOCK=false
# PostHog — analytics de funnel (opcional en local; sin key los eventos son no-op)
VITE_POSTHOG_KEY=
# Región del proyecto: us.i.posthog.com (default) o eu.i.posthog.com — debe coincidir con Project Settings
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — monitoreo de errores (opcional en local; sin DSN el SDK es no-op)
# Frontend (Vite): usar VITE_SENTRY_DSN; NEXT_PUBLIC_SENTRY_DSN se acepta como alias.
VITE_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# API (Node/Express)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Subida de source maps en build de producción (CI); sin token los .map no se publican al bundle
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
