{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:new-student": "tsx prisma/seed-new-student.ts",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "deploy:verify-config": "node scripts/verify-deploy-track-a.mjs",
    "deploy:verify-production": "node scripts/verify-production-t1.mjs",
    "deploy:verify-funnel": "node scripts/verify-funnel-track-a.mjs",
    "db:test-connection": "node --env-file=.env scripts/test-db-connection.mjs",
    "api:dev": "NODE_ENV=development tsx --env-file=.env --import ./sentry.server.instrument.ts server/index.ts",
    "app:typecheck": "tsc -p tsconfig.app.json --noEmit",
    "api:typecheck": "tsc -p tsconfig.server.json --noEmit",
    "typecheck": "npm run app:typecheck && npm run api:typecheck",
    "test": "npm run app:test && npm run api:test",
    "verify": "npm run typecheck && npm run test && npm run build",
    "api:test": "NODE_ENV=test node scripts/ops/run-api-tests.mjs",
    "api:test:docker": "NODE_ENV=test GMUSIC_API_TEST_DB=docker node scripts/ops/run-api-tests.mjs",
    "ops:test-db-guard": "node --test scripts/ops/db-env-guard.test.mjs",
    "app:test": "node --import tsx --test 'src/**/*.test.ts'"
  },
